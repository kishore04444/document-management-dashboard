{
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "vite",
            "buildCommand": "npm run build",
            "outputDirectory": "dist",
            "installCommand": "npm install"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/api",
            "framework": "node",
            "buildCommand": "npm install",
            "startCommand": "node src/server.js"
        }
    }
}
